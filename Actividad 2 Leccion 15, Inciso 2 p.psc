Algoritmo Billetes_de_100
	Definir b1, b2, b3, tb, td Como Real
	Escribir "Cantidad de billetes de 20"
	leer b1
	Escribir "Cantidad de billetes de 50"
	leer b2
	Escribir "Cantidad de billetes de 100"
	leer b3
	
	tb=b1+b2+b3
	td=b3*100
	
	Escribir "Total de billetes: ", tb
	Escribir "Total de Billetes de 100: ", b3
	Escribir "Total de dinero de los billetes de 100: Q", td
FinAlgoritmo
