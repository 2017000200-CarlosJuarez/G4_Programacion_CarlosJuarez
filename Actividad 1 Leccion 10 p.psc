Algoritmo cuponeria
	Definir i como real
    Escribir "------Cupones de Presi(Dipru)------"
    Para i=1 hasta 8 Con Paso 1 Hacer
        Escribir "Escribir una tecla para marcar el sello numero: ",i
        Esperar Tecla
        Escribir "El sello ",i," Marcado..."
        Escribir "***********************"
    FinPara
    Escribir "Felicidades has cumplido los 8 sellos"
    Escribir "Corte Gratis"
FinAlgoritmo 	

